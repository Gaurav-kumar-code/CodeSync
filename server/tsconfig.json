{
	"compilerOptions": {
		"target": "ES2020",
		"module": "CommonJS",
		"moduleResolution": "Node",
		"rootDir": "./src",
		"strict": true,
		"noImplicitAny": false,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"ignoreDeprecations": "5.0",
		"resolveJsonModule": true,
		"outDir": "./dist"
	},
	"include": ["src"],
	"exclude": ["node_modules"]
}
